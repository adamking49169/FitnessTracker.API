// appsettings.json
{
  "ConnectionStrings": {
    "SqlServer": "<SQL_CONNECTION_STRING>",
    "CosmosDb": "<COSMOS_CONNECTION_STRING>"
  },

  "Cosmos": {
    "Database": "FitnessTracker",
    "Container": "Exercises"
  },

  "Jwt": {
    "Issuer": "https://localhost:44363",
    "Audience": "https://localhost:44363",
    "Key": "<JWT_KEY>"
  },

  "OpenAI": {
    "ApiKey": "<OPENAI_API_KEY>"
  },

  "NutritionApis": {
    "NutritionixAppId": "<NUTRITIONIX_APP_ID>",
    "NutritionixAppKey": "<NUTRITIONIX_APP_KEY>"
  },

  "Logging": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
